# Per-run config. Sourced by bin/ralph-runner and skills/step for THIS run only.
# State files are fixed-name within this run dir (spec.json, PROGRESS.md,
# OVERNIGHT.md, .timeout-pending) — not configurable, so runs never collide.
#
# Override layer: a gitignored sibling ralph.config.local is sourced after this
# file and wins. Use it for per-machine paths, tuning, and cost fields. The values
# below are stable defaults intended to be overridden in ralph.config.local.
# Identity fields (RALPH_RUN_ID / RALPH_BRANCH / RALPH_TEST_DIR / RALPH_STEP_SKILL)
# must NOT be overridden in ralph.config.local — the runner will abort if any change.

RALPH_RUN_ID="2026-06-10-nanoclaw-admin-mcp-generic"
RALPH_REPO="/Users/dustin/Source/pan/nanoclaw"          # the project the loop builds
RALPH_PLUGIN_DIR="/Users/dustin/Source/ralph-kit"      # where the ralph-kit plugin lives
RALPH_BRANCH="ralph/2026-06-10-nanoclaw-admin-mcp-generic"                   # per-run; never the default branch
RALPH_STEP_SKILL="/ralph-kit:step"              # invoked fresh each round
RALPH_ROUND_TIMEOUT="1200"                      # seconds (20m). perl-alarm shim if no `timeout`
RALPH_BREAKER_N="5"                             # circuit breaker: FAIL rounds per step
RALPH_MAX_ROUNDS="60"                           # safety cap per launch
RALPH_TEST_DIR=".ralph/runs/2026-06-10-nanoclaw-admin-mcp-generic/tests"     # G2: per-run test corpus; breakdown substitutes <run-id>
RALPH_GATE_TIMEOUT="1200"                       # G2: whole-suite time bound at Phase-GATE (seconds)
RALPH_REDECOMPOSE="0"                           # G1: 0=off (stop at STUCK); 1=invoke redecompose on STUCK
RALPH_REDECOMPOSE_MAX="1"                       # G1: max re-decompose depth per task lineage
RALPH_STEP_MODEL="claude-sonnet-4-6"            # model for every step round; always passed explicitly (ignores project default)
RALPH_ADVISOR_MODEL="claude-fable-5"           # model for redecompose rounds and --advisor escalation
RALPH_LINT="1"                                  # run bin/ralph-lint-spec before the loop; set 0 to bypass

# ── cost metering (per-round capture is always on; these only add caps/labels) ──
RALPH_ROUND_BUDGET=""                           # optional hard per-round $ cap (claude --max-budget-usd); empty = uncapped
RALPH_RUN_BUDGET=""                             # optional run $ budget; ENFORCED — stops before the round projected to breach it
# RALPH_RUN_BUDGET_SIGMA=2                       # error-bar width: project next round at mean + Nσ of recent rounds (default 2)
# RALPH_RUN_BUDGET_WINDOW=5                      # recent non-zero rounds feeding the error bar (default 5)
# RALPH_RUN_BUDGET_AUTOEXTEND=0                  # unattended (no tty) top-ups allowed at the band; default 0 = hard-stop
# RALPH_RUN_BUDGET_PROMPT=1                      # set 0 to suppress the attended top-up prompt (hard-stop instead)
# RALPH_METRICS_DIR=...                         # override the global ROI store dir (default: $XDG_DATA_HOME/ralph-kit)
# RALPH_METRICS=0                               # disable the global cross-repo ROI summary write (per-run cost.jsonl still written)
