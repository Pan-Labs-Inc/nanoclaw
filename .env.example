# SMS / Twilio
#
# Required when enabling the native SMS channel. Production installs should use
# a Twilio Messaging Service SID (MG...) with Advanced Opt-Out enabled.
#
# Twilio must POST inbound messages to:
#   https://<host>/webhook/sms
# and status callbacks to:
#   https://<host>/webhook/sms/status
#
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_MESSAGING_SERVICE_SID=
TWILIO_SMS_WEBHOOK_URL=
TWILIO_SMS_STATUS_CALLBACK_URL=
TWILIO_VALIDATE_SIGNATURE=true

# Admin MCP endpoint (POST /webhook/admin-mcp)
#
# Bearer token for the admin MCP API. Generate with:
#   openssl rand -hex 32
# Leave blank to disable the endpoint entirely.
NANOCLAW_ADMIN_MCP_TOKEN=
#
# Optional: comma-separated group-name prefixes. When set, group_put,
# group_file_get, group_file_put, group_mount_set, and dm_register reject
# any groupName that does not start with a listed prefix. Unset = no restriction.
# Example: NANOCLAW_ADMIN_MCP_GROUP_PREFIXES=sms-,prod-
NANOCLAW_ADMIN_MCP_GROUP_PREFIXES=

# Enables authenticated Pantalaimon SMS enrollment/control over
# POST /webhook/pan-mcp. Leave blank to disable the endpoint.
NANOCLAW_PAN_MCP_TOKEN=

# Local/dev only fallback sender. Production should leave this blank and use
# TWILIO_MESSAGING_SERVICE_SID above.
TWILIO_PHONE_NUMBER=
TWILIO_FROM_NUMBER=
NANOCLAW_SMS_ALLOW_PHONE_SENDER=false
